{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "kafkaReceivers": {
      "type": "array",
      "description": "Kafka receivers configuration. At least one receiver is required (validated at template render time).",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name for this receiver (used in pipelines)"
          },
          "brokers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of Kafka broker addresses (e.g., [\"broker1:9092\", \"broker2:9092\"])"
          },
          "logs": {
            "type": "object",
            "description": "Logs configuration (topics, encoding, etc.)"
          },
          "group_id": {
            "type": "string",
            "description": "Kafka consumer group ID"
          },
          "tls": {
            "type": "object",
            "description": "TLS configuration for Kafka broker connection (e.g. when using port 9093). Passed through to the receiver; common options include insecure_skip_verify, ca_pem, ca_file. See docs/tls.md."
          }
        }
      }
    },
    "splunkExporters": {
      "type": "array",
      "description": "Splunk HEC exporters configuration. At least one exporter is required (validated at template render time).",
      "items": {
        "type": "object",
        "required": ["name", "endpoint"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name for this exporter (used in pipelines)"
          },
          "endpoint": {
            "type": "string",
            "description": "Splunk HEC endpoint URL (e.g., https://splunk-hec:8088/services/collector)"
          },
          "token": {
            "type": "string",
            "description": "HEC token (or use 'secret' field to reference existing secret)"
          },
          "secret": {
            "type": "string",
            "description": "Name of existing Kubernetes secret containing 'splunk-hec-token' key"
          },
          "source": {
            "type": "string",
            "description": "Source field for Splunk events"
          },
          "sourcetype": {
            "type": "string",
            "description": "Sourcetype for Splunk events"
          },
          "index": {
            "type": "string",
            "description": "Splunk index name"
          },
          "tls": {
            "type": "object",
            "description": "TLS configuration"
          },
          "sending_queue": {
            "$ref": "#/definitions/sendingQueue"
          }
        }
      }
    },
    "pipelines": {
      "type": "array",
      "description": "Pipelines configuration. At least one pipeline is required (validated at template render time).",
      "items": {
        "type": "object",
        "required": ["name", "type", "receivers", "exporters"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name for this pipeline"
          },
          "type": {
            "type": "string",
            "enum": ["logs", "metrics", "traces"],
            "description": "Pipeline type (logs, metrics, or traces)"
          },
          "receivers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "List of receiver names (must match names in kafkaReceivers)"
          },
          "exporters": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "List of exporter names (must match names in splunkExporters)"
          },
          "processors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of processor names. If omitted, defaults.pipelineProcessors is used (default: [\"resourcedetection\"])"
          }
        }
      }
    }
  },
  "definitions": {
    "sendingQueue": {
      "type": "object",
      "description": "Splunk HEC exporter sending queue and exporter-level batching configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the exporter sending queue"
        },
        "num_consumers": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Number of queue consumers that dequeue and export batches"
        },
        "queue_size": {
          "type": "integer",
          "minimum": 1,
          "default": 10000,
          "description": "Maximum queue size measured by the configured sizer"
        },
        "block_on_overflow": {
          "type": "boolean",
          "default": true,
          "description": "Block until queue space is available instead of rejecting data immediately when the queue is full"
        },
        "sizer": {
          "type": "string",
          "enum": ["requests", "items", "bytes"],
          "default": "items",
          "description": "Unit used to size the queue"
        },
        "batch": {
          "type": "object",
          "description": "Exporter-level batching configuration inside the sending queue",
          "additionalProperties": false,
          "properties": {
            "min_size": {
              "type": "integer",
              "minimum": 1,
              "default": 8192,
              "description": "Minimum batch size before export"
            }
          }
        }
      }
    }
  }
}
