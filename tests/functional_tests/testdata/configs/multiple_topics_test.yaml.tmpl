---
receivers:
  kafka/{{ .KafkaTopicName1 }}:
    brokers: [ {{ .KafkaBrokerAddress }} ]
    logs:
      topics:
        - {{ .KafkaTopicName1 }}
      encoding: "text"
  kafka/{{ .KafkaTopicName2 }}:
    brokers: [ {{ .KafkaBrokerAddress }} ]
    logs:
      topics:
        - {{ .KafkaTopicName2 }}
      encoding: "text"

exporters:
  splunk_hec/{{ .KafkaTopicName1 }}:
    token: {{ .SplunkHECToken }}
    endpoint: {{ .SplunkHECEndpoint }}
    tls:
      insecure_skip_verify: true
    source: {{ .Source1 }}
    sourcetype: {{ .Sourcetype }}
    index: {{ .Index }}
    sending_queue:
      enabled: true
      num_consumers: 10
      queue_size: 10000
      block_on_overflow: true
      sizer: items
      batch:
        min_size: 8192
  splunk_hec/{{ .KafkaTopicName2 }}:
    token: {{ .SplunkHECToken }}
    endpoint: {{ .SplunkHECEndpoint }}
    tls:
      insecure_skip_verify: true
    source: {{ .Source2 }}
    sourcetype: {{ .Sourcetype }}
    index: {{ .Index }}
    sending_queue:
      enabled: true
      num_consumers: 10
      queue_size: 10000
      block_on_overflow: true
      sizer: items
      batch:
        min_size: 8192

service:
  telemetry:
    logs:
      level: info
      output_paths:
        - ../logs/multiple-topics-otel-collector.log
        - stdout
      error_output_paths:
        - ../logs/multiple-topics-otel-collector-errors.log
        - stderr
  pipelines:
    logs/1:
      receivers: [ kafka/{{ .KafkaTopicName1 }} ]
      exporters: [ splunk_hec/{{ .KafkaTopicName1 }} ]
    logs/2:
      receivers: [ kafka/{{ .KafkaTopicName2 }} ]
      exporters: [ splunk_hec/{{ .KafkaTopicName2 }} ]
